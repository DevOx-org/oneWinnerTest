NODE_ENV=development
PORT=5001

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?appName=<app>

JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRE=7d

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_PUBLIC_MAX=200
RATE_LIMIT_GENERAL_MAX=300
RATE_LIMIT_CRITICAL_MAX=100

# Redis (optional — falls back to in-memory if not set)
# Use rediss:// (double s) for TLS connections (required by Upstash)
REDIS_URL=rediss://default:your-password@your-host.upstash.io:6379

# Room credentials cache TTL (seconds)
ROOM_CACHE_TTL=300

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

ADMIN_UPI_ID=your-upi-id@bank

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
FRONTEND_URL=http://localhost:5173

LOG_FILTER_MODE=all
LOG_FILTER_ROLE=
LOG_FILTER_USER_ID=
LOG_SHOW_ROLE=false
